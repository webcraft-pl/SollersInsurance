# Skopiuj jako .env.local i uzupełnij wartości

# Anthropic API — używane tylko server-side (api/flood-check.ts, api/generate-packages.ts)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — publishable key (bezpieczny po stronie klienta)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
